NODE_ENV=development
PORT=3000
TZ=UTC

# Database (Mục 8 ruleset - DB riêng cho NestJS, cong 5433)
# Postgres dang chay che do trust (khong yeu cau mat khau) - chi dung cho local dev
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=
DB_NAME=store_nestjs

# Redis (chuẩn bị cho Ngày 8 - cache)
REDIS_URL=redis://localhost:6380
REDIS_CACHE_TTL=3600

# JWT (Mục 11 ruleset - access ngắn hạn, refresh dài hạn)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRATION_DAYS=7

BCRYPT_SALT_ROUNDS=10

PRODUCT_EXPIRY_ALERT_DAYS=7

